@model GestaoEventos.Models.Eventos

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5">
        <div class="card shadow border-0 p-4">
            <h4 class="text-warning mb-3">
                <i class="fa-solid fa-pen-to-square me-2"></i>Editar Categoria
            </h4>
            <hr />
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Nome" class="form-control" placeholder="Título" />
                    <label asp-for="Nome"></label>
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Data" type="text" id="datepicker" class="form-control" placeholder="Selecione a data" />
                    <label asp-for="Data">Data do Evento</label>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small">Categoria do Evento</label>
                    <select asp-for="CategoriaId" class="form-select border-primary" asp-items="ViewBag.CategoriaId">
                        <option value="">-- Selecione uma Categoria --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small">Local do Evento</label>
                    <select asp-for="LocalId" class="form-select border-primary" asp-items="ViewBag.LocalId">
                        <option value="">-- Selecione um Local --</option>
                    </select>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-warning py-2 shadow-sm text-white fw-bold">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Salvar Alterações
                    </button>
                    <a asp-action="Index" class="btn btn-link text-muted">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>